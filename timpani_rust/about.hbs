<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Third Party Licenses — timpani-rust</title>
  <style>
    body { font-family: sans-serif; max-width: 960px; margin: 2rem auto; padding: 0 1rem; }
    h1 { border-bottom: 2px solid #333; padding-bottom: 0.5rem; }
    h2 { margin-top: 2rem; color: #2a5db0; }
    .used-by { font-size: 0.9em; color: #555; margin-bottom: 0.5rem; }
    pre { background: #f5f5f5; padding: 1rem; overflow-x: auto; white-space: pre-wrap; word-wrap: break-word; border-left: 4px solid #ccc; }
    hr { border: none; border-top: 1px solid #ddd; margin: 2rem 0; }
  </style>
</head>
<body>
  <h1>Third Party License Report</h1>
  <p>Generated by <a href="https://github.com/EmbarkStudios/cargo-about">cargo-about</a> for the <strong>timpani-rust</strong> workspace.</p>

  {{#each licenses}}
  <h2>{{name}} <small>({{id}})</small></h2>
  <div class="used-by">
    Used by:
    {{#each used_by}}
      <a href="{{crate.repository}}">{{crate.name}} {{crate.version}}</a>{{#unless @last}}, {{/unless}}
    {{/each}}
  </div>
  <pre>{{text}}</pre>
  <hr>
  {{/each}}
</body>
</html>
